# Flask
SECRET_KEY=isp-secret-key-change-in-production

# Facebook OAuth — create app at https://developers.facebook.com
# Set redirect URI to: http://localhost:5000/auth/facebook/callback
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# Google OAuth — create credentials at https://console.cloud.google.com
# Set redirect URI to: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
